{
  "$schema": "https://code.claude.com/schemas/mcp.json",
  "mcpServers": {
    "claude-crap": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/bundle/mcp-server.mjs",
        "--transport",
        "stdio"
      ],
      "env": {
        "NODE_ENV": "production",
        "CLAUDE_CRAP_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  }
}
