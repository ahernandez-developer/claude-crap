# --- Node / npm ---------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
*.tgz

# --- TypeScript build output -------------------------------------------
# `dist/` is rebuilt by the `postinstall` + `prepublishOnly` scripts and
# shipped to the npm tarball via `package.json#files`. It is NOT tracked
# in git so source-of-truth stays in `src/`.
dist/
*.tsbuildinfo

# --- claude-sonar workspace state --------------------------------------
# The plugin writes its consolidated SARIF report and per-run metrics
# into `.claude-sonar/` inside whatever workspace the user is developing
# in. That state is per-developer, per-session — never commit it.
.claude-sonar/
.codesight/

# --- Environment / secrets ---------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# --- Test + coverage output --------------------------------------------
coverage/
.nyc_output/
*.lcov
.cache/

# --- Editor / IDE state ------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# --- OS metadata -------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
