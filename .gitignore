# --- Node / npm ---------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
*.tgz

# --- TypeScript build output -------------------------------------------
# `dist/` is rebuilt by postinstall + prepublishOnly for the npm library
# distribution (`claude-crap/metrics` etc.). It is NOT tracked
# in git. The git-source plugin distribution uses `plugin/bundle/` which
# IS tracked — see `scripts/bundle-plugin.mjs`.
dist/
*.tsbuildinfo

# --- Plugin bundle artifacts -------------------------------------------
# plugin/bundle/*.mjs files are committed (they ARE the runtime artifact
# for git-source installs). Source maps and node_modules are not.
plugin/node_modules/
plugin/bundle/**/*.map

# --- claude-crap workspace state --------------------------------------
# The plugin writes its consolidated SARIF report and per-run metrics
# into `.claude-crap/` inside whatever workspace the user is developing
# in. That state is per-developer, per-session — never commit it.
.claude-crap/
.codesight/

# --- Environment / secrets ---------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# --- Test + coverage output --------------------------------------------
coverage/
.nyc_output/
*.lcov
.cache/

# --- Editor / IDE state ------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# --- OS metadata -------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
